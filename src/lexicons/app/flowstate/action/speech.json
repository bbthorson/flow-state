{
  "lexicon": 1,
  "id": "app.flowstate.action.speech",
  "description": "Speaks text aloud using the Web Speech API (text-to-speech).",
  "defs": {
    "main": {
      "type": "object",
      "description": "Text to Speech action configuration.",
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "description": "Text to speak. Supports {{variable}} template syntax."
        },
        "rate": {
          "type": "number",
          "description": "Speech rate. 1.0 is normal speed.",
          "minimum": 0.1,
          "maximum": 10,
          "default": 1
        },
        "pitch": {
          "type": "number",
          "description": "Voice pitch. 1.0 is normal.",
          "minimum": 0,
          "maximum": 2,
          "default": 1
        },
        "volume": {
          "type": "number",
          "description": "Volume level.",
          "minimum": 0,
          "maximum": 1,
          "default": 1
        }
      },
      "permissions": ["speech-synthesis"]
    }
  }
}
