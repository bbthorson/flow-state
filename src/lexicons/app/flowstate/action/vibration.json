{
  "lexicon": 1,
  "id": "app.flowstate.action.vibration",
  "description": "Vibrates the device for haptic feedback. Uses the Vibration API.",
  "defs": {
    "main": {
      "type": "object",
      "description": "Vibration action configuration.",
      "properties": {
        "duration": {
          "type": "integer",
          "description": "Single vibration duration in milliseconds.",
          "minimum": 1
        },
        "pattern": {
          "type": "array",
          "description": "Alternating vibrate/pause durations in milliseconds.",
          "items": { "type": "integer", "minimum": 0 }
        }
      },
      "permissions": ["vibration"]
    }
  }
}
