{
  "lexicon": 1,
  "id": "app.flowstate.defs",
  "description": "Shared definitions for the Flow State automation platform.",
  "defs": {
    "permission": {
      "type": "string",
      "description": "A browser permission or API capability required by a trigger or action.",
      "knownValues": [
        "battery-status",
        "network-information",
        "geolocation",
        "notifications",
        "idle-detection",
        "device-motion",
        "screen-orientation",
        "vibration",
        "clipboard-write",
        "web-share",
        "wake-lock",
        "speech-synthesis"
      ]
    },
    "triggerInput": {
      "type": "union",
      "description": "All supported trigger types.",
      "refs": [
        "app.flowstate.trigger.battery",
        "app.flowstate.trigger.network",
        "app.flowstate.trigger.geolocation",
        "app.flowstate.trigger.deepLink",
        "app.flowstate.trigger.manual",
        "app.flowstate.trigger.idle",
        "app.flowstate.trigger.motion",
        "app.flowstate.trigger.orientation"
      ],
      "closed": false
    },
    "actionInput": {
      "type": "union",
      "description": "All supported action types.",
      "refs": [
        "app.flowstate.action.webhook",
        "app.flowstate.action.notification",
        "app.flowstate.action.log",
        "app.flowstate.action.vibration",
        "app.flowstate.action.clipboard",
        "app.flowstate.action.share",
        "app.flowstate.action.wakeLock",
        "app.flowstate.action.speech"
      ],
      "closed": false
    }
  }
}
